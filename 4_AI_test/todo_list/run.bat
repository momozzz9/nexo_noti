@echo off
echo ==========================================
echo   Todo List 개발 서버를 시작합니다...
echo ==========================================
echo.

:: 프로젝트 폴더로 이동 (현재 위치가 프로젝트 폴더가 아닐 경우를 대비)
cd /d "%~dp0"

:: 1. 종속성 설치 확인 (생략 가능하지만 안전을 위해 포함)
echo [1/2] 필요한 패키지를 확인 중입니다...
call npm install

echo.
:: 2. 개발 서버 실행 및 브라우저 열기
echo [2/2] 서버를 실행하고 브라우저를 엽니다...
echo (서버를 종료하려면 이 창에서 Ctrl+C를 누르세요.)
echo.
call npm run dev -- --open

pause
